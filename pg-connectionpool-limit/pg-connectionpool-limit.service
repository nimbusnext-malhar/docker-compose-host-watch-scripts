[Unit]
Description=Service to run powershell script for checking PostgreSQL connection pool limits on an interval

[Service]
Type=oneshot
WorkingDirectory=/home/civitaiusr
ExecStart=/usr/bin/pwsh -File /home/civitaiusr/host-watch-scripts/pg-connectionpool-limit/pg-connectionpool-limit.ps1
StandardOutput=journal
StandardError=journal
SyslogIdentifier=pg-connectionpool-limit
